# PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/worldstar?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# S3-compatible object storage (AWS S3, Cloudflare R2, MinIO)
S3_REGION="us-east-1"
S3_BUCKET="worldstar-uploads"
S3_ACCESS_KEY_ID="changeme"
S3_SECRET_ACCESS_KEY="changeme"
# Optional: custom endpoint for R2/MinIO
S3_ENDPOINT=""
# Public CDN base that fronts the bucket (CloudFront / R2 custom domain)
CDN_BASE_URL="https://cdn.example.com"

# Secret bearer token for the cron flush endpoint
CRON_SECRET="generate-a-long-random-string"

# HMAC secret for staff session tokens
SESSION_SECRET="generate-another-long-random-string"
